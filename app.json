{
  "expo": {
    "name": "Dehouse Market",
    "slug": "controle-compras",
    "scheme": "dehousemarket",
    "version": "1.0.45",
    "jsEngine": "hermes",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#FFFFFF"
    },
    "react-native-google-mobile-ads": {
      "android_app_id": "ca-app-pub-5151678673256465~1476333427",
      "ios_app_id": "ca-app-pub-5151678673256465~1476333427"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "A aplicação precisa de aceder à câmara para ler o QR Code das notas fiscais e escanear produtos."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "A aplicação precisa de acesso ao microfone para permitir a adição de produtos por comando de voz na lista de planeamento."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "A aplicação precisa de acesso ao microfone para adicionar produtos por voz.",
          "speechRecognitionPermission": "A aplicação precisa de aceder ao reconhecimento de voz para converter as palavras faladas em texto."
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-5151678673256465~1476333427",
          "iosAppId": "ca-app-pub-5151678673256465~1476333427"
        }
      ],
      "@react-native-google-signin/google-signin",
      "expo-secure-store",
      "expo-web-browser",
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "newArchEnabled": true
          }
        }
      ]
    ],
    "ios": {
      "bundleIdentifier": "com.detech.dehousemarket",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "A aplicação precisa de aceder à câmara para ler o QR Code das notas fiscais e escanear produtos.",
        "NSMicrophoneUsageDescription": "A aplicação precisa de acesso ao microfone para permitir a adição de produtos por comando de voz na lista de planeamento.",
        "NSSpeechRecognitionUsageDescription": "A aplicação precisa de aceder ao reconhecimento de voz para converter as palavras faladas em texto."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.detech.dehousemarket",
      "versionCode": 57,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET"
      ]
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "03239695-f821-4eca-bf59-27a0dd0e6ac0"
      }
    },
    "owner": "junins_21"
  }
}